TZ=Asia/Seoul
PYTHONUNBUFFERED=1

# Shared Mongo that the web server reads from
MONGO_URI=mongodb://127.0.0.1:27017
DB_NAME=stock_data

# Required for DART-based event/financial refresh jobs
OPEN_DART_API_KEY=

# Optional: only needed if you later enable Slack/error notifications
SLACK_WEBHOOK_URL=

# Optional tuning
WS_MAX_WORKERS=1
WICS_CORE_LIMIT=12
WICS_DYNAMIC_LIMIT=4
WICS_TOTAL_LIMIT=16
WICS_DYNAMIC_MIN_SCORE=0.54
WICS_DYNAMIC_MIN_SOURCES=2
FLOW_SNAPSHOT_INTERVAL_SEC=180
FLOW_SNAPSHOT_MIN_GROSS_AMT_MIL=50
FLOW_SNAPSHOT_FORCE_GROSS_AMT_MIL=300
READ_API_PORT=8000
